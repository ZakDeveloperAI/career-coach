# Copia in .env e riempi i valori. Mai committare .env.

# Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash

# JWT - genera una stringa random di almeno 32 caratteri
JWT_SECRET=<random-32-chars>
JWT_EXPIRATION_MINUTES=120

# Adzuna (https://developer.adzuna.com/)
ADZUNA_APP_ID=<your-adzuna-app-id>
ADZUNA_APP_KEY=<your-adzuna-app-key>
ADZUNA_COUNTRY=it

# RemoteOK (nessuna chiave necessaria)
REMOTEOK_ENABLED=true

# Admin di default (creato al primo avvio se non esistono admin)
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=<change-on-first-login>
