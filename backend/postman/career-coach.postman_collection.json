  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Candidate",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('candidate_token', j.token);",
                  "pm.collectionVariables.set('candidate_id', j.userId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"email\": \"candidate@test.com\",\n  \"password\": \"password123\",\n  \"name\": \"Mario\",\n  \"surname\": \"Rossi\",\n  \"role\": \"CANDIDATE\"\n}"},
            "url": {"raw":"{{base_url}}/auth/register","host":["{{base_url}}"],"path":["auth","register"]}
          }
        },
